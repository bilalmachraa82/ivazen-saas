# ── Frontend (Vite) ──────────────────────────────────────
# Required — Supabase project connection
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional — Error monitoring
# VITE_SENTRY_DSN=https://your-sentry-dsn

# ── Admin / Scripts ──────────────────────────────────────
# Only needed for migration scripts (never commit the real value)
# SUPABASE_SERVICE_KEY=your-service-role-key

# ── E2E Tests (Playwright) ──────────────────────────────
# Required for `npm run e2e`
# E2E_BASE_URL=http://localhost:8080
# DEMO_EMAIL=test-user@example.com
# DEMO_PASSWORD=test-password

# ── Supabase Edge Function Secrets ──────────────────────
# Set these in Supabase Dashboard > Edge Functions > Secrets
# AI_API_KEY=your-google-ai-studio-key
# AT_CONNECTOR_URL=http://your-vps-ip:8788
# AT_CONNECTOR_TOKEN=your-connector-token
# AT_ENCRYPTION_KEY=your-aes-256-key
